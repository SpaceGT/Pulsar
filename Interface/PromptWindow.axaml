<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Pulsar.Interface.PromptWindow"
        Width="520"
        MinHeight="210"
        SizeToContent="Height"
        CanResize="False"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        Background="#252F35">
  <Grid RowDefinitions="Auto,*,Auto">
    <Border Name="Header" Background="#3C4C52" Padding="18,12">
      <TextBlock Name="Heading" Foreground="White" FontSize="22" />
    </Border>
    <TextBlock Name="MessageText"
               Grid.Row="1"
               Margin="24"
               Foreground="White"
               FontSize="16"
               TextWrapping="Wrap" />
    <StackPanel Name="ButtonsPanel"
                Grid.Row="2"
                Margin="24,0,24,20"
                HorizontalAlignment="Right"
                Orientation="Horizontal"
                Spacing="12" />
  </Grid>
</Window>
