<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="Pulsar.Interface.SplashWindow"
        Width="675"
        Height="375"
        CanResize="False"
        ShowInTaskbar="True"
        SystemDecorations="None"
        WindowStartupLocation="CenterScreen"
        Background="#050708"
        Title="Pulsar">
  <Grid Margin="10" RowDefinitions="*,42,14">
    <Grid Grid.Row="0" ColumnDefinitions="45*,55*">
      <Image Source="avares://Pulsar.Interface/Assets/throbber.gif" Stretch="Uniform" />
      <Image Grid.Column="1"
             Source="avares://Pulsar.Interface/Assets/text.png"
             Stretch="Uniform" />
    </Grid>
    <TextBlock Name="ProgressText"
               Grid.Row="1"
               VerticalAlignment="Center"
               HorizontalAlignment="Center"
               Foreground="White"
               FontSize="16" />
    <ProgressBar Name="ProgressBar"
                 Grid.Row="2"
                 Minimum="0"
                 Maximum="1"
                 IsVisible="False" />
  </Grid>
</Window>
