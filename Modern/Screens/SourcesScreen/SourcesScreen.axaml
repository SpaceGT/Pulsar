<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
             x:Class="Pulsar.Modern.Screens.SourcesScreen.SourcesScreen">
    <Border Background="rgba(37,47,53,96)"
			BorderBrush="rgba(66,77,99,96)"
			BorderThickness="1.5" 
			Width="1441" 
			Height="972">
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto" Margin="30">
			<Grid Grid.Row="0">
				<TextBlock HorizontalAlignment="Center"
					   FontSize="25"
					   FontWeight="Normal"
					   Foreground="White"
					   Text="Sources"/>
				<Button Name="CornerCancelButton" Classes="Menu" 
						Width="40" 
						Height="40" 
						HorizontalAlignment="Right" 
						HorizontalContentAlignment="Center" 
						VerticalContentAlignment="Center"
						FontSize="40"
						Click="CornerCancelButton_Click">
					<Image Source="{DynamicResource IconsConfiguration_CrossIcon}"/>
				</Button>
			</Grid>
			<Separator Grid.Row="1" Background="rgb(77,99,96)" Margin="0,16,0,0"/>
        </Grid>
    </Border>
</UserControl>
